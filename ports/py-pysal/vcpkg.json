{
  "name": "py-pysal",
  "version": "26.1",
  "port-version": 2,
  "description": "Python Spatial Analysis Library - meta-package for the PySAL ecosystem.",
  "homepage": "https://pysal.org/",
  "license": "BSD-3-Clause",
  "dependencies": [
    "py-lazy-loader",
    {
      "name": "py-setuptools",
