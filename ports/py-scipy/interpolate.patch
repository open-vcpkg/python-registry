+        j = 0;
+        if (iop0 != 0) {
+            for (l = 1; l <= nv4; l++) {
+                i++;
+                q[i - 1] = c0[l - 1];
+            }
+        }
+        if (iop1 != 0) {
+            for (l = 1; l <= nv4; l++) {
+                i++;
+                q[i - 1] = c1[l - 1];
+            }
+        }
+        for (i = 1; i <= ncof; i++) {
+            c[i - 1] = q[i - 1];
+        }
+        // calculate the quantities
+        //   res(i,j) = (r(i,j) - s(u(i),v(j)))**2 , i=1,2,..,mu;j=1,2,..,mv
+        //   fp = sumi=1,mu(sumj=1,mv(res(i,j)))
+        //   fpu(r) = sum''i(sumj=1,mv(res(i,j))) , r=1,2,...,nu-7
+        //                 tu(r+3) <= u(i) <= tu(r+4)
+        //   fpv(r) = sumi=1,mu(sum''j(res(i,j))) , r=1,2,...,nv-7
+        //                 tv(r+3) <= v(j) <= tv(r+4)
+        *fp = 0.0;
+        for (i = 1; i <= nu; i++) {
+            fpu[i - 1] = 0.0;
+        }
+        for (i = 1; i <= nv; i++) {
+            fpv[i - 1] = 0.0;
+        }
+        ir = 0;
+        nroldu = 0;
+        // main loop for the different grid points.
+        for (i1 = 1; i1 <= mu; i1++) {
+            numu = nru[i1 - 1];
+            numu1 = numu + 1;
+            nroldv = 0;
+            for (i2 = 1; i2 <= mv; i2++) {
+                numv = nrv[i2 - 1];
+                numv1 = numv + 1;
+                ir++;
