-      f2 = 0.
-      i = 4
-      do 200 j=1,5
-        i = i+1
-        ai = i
-        fac = fac*alfa/ai
-        f2 = f2+fac
-        if(abs(fac).le.eps) go to 300
-        i = i+1
-        ai = i
-        fac = -fac*alfa/ai
-        f1 = f1+fac
-        if(abs(fac).le.eps) go to 300
- 200  continue
- 300  ress = ab4*(coa*f2+sia*f1)
-      resc = ab4*(coa*f1-sia*f2)
- 400  return
-      end
