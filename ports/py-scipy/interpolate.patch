- 120  continue
-c  the scaling factors are taken into account.
- 130  f = one/ak
-      do 140 i=1,nk1
-        j = i+k1
-        bint(i) = bint(i)*(t(j)-t(i))*f
- 140  continue
-c  the order of the integration limits is taken into account.
-      if(min.eq.0) go to 160
-      do 150 i=1,nk1
-        bint(i) = -bint(i)
- 150  continue
