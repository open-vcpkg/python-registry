-        l0 = l+1
-        go to 40
-c  calculation of aint(j), j=1,2,...,k+1.
-c  initialization.
-  50    do 55 j=1,k1
-          aint(j) = 0.0d0
-  55    continue
-        aint(1) = (arg-t(l))/(t(l+1)-t(l))
-        h1(1) = one
-        do 70 j=1,k
-c  evaluation of the non-zero b-splines of degree j at arg,i.e.
