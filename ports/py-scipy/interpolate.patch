-            li = l+i
-            lj = li-j1
-            aint(i) = aint(i)+h(i)*(arg-t(lj))/(t(li)-t(lj))
-            h1(i) = h(i)
-  70    continue
-        if(it.eq.2) go to 100
-c  updating of the integrals bint
-        lk = l-k
-        ia = lk
-        do 80 i=1,k1
-          bint(lk) = -aint(i)
-          lk = lk+1
-  80    continue
-c  set arg = b.
-        arg = b
-  90  continue
-c  updating of the integrals bint.
- 100  lk = l-k
-      ib = lk-1
-      do 110 i=1,k1
-        bint(lk) = bint(lk)+aint(i)
-        lk = lk+1
- 110  continue
-      if(ib.lt.ia) go to 130
-      do 120 i=ia,ib
