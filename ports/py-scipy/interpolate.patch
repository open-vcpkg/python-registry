+static void
+fprota(const double c, const double s, double* restrict a, double* restrict b)
+{
+    // fprota applies a givens rotation to the pair (a,b).
+    double temp = c * (*a) - s * (*b);
+    *b          = c * (*b) + s * (*a);
+    *a          = temp;
+}
