{
  "name": "py-numpy",
  "version": "2.4.3",
  "port-version": 3,
  "description": "The fundamental package for scientific computing with Python.",
  "homepage": "https://www.numpy.org/",
  "license": "BSD-3-Clause",
  "dependencies": [
    {
      "name": "blas",
      "platform": "!osx"
    },
    {
      "name": "lapack",
      "platform": "!osx"
    },
    "python3",
    {
      "name": "vcpkg-python-scripts",
      "host": true,
      "features": [
        "cython",
        "meson"
      ]
    },
    {
      "name": "vcpkg-tool-mesonpy",
      "host": true
    }
  ]
}
