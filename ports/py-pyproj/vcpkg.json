{
  "name": "py-pyproj",
  "version": "3.7.2",
  "port-version": 1,
  "description": "Python interface to PROJ (cartographic projections and coordinate transformations library).",
  "homepage": "https://pyproj4.github.io/pyproj/",
  "dependencies": [
    {
      "name": "proj",
      "default-features": false
    },
    "py-certifi",
    "python3",
    {
      "name": "vcpkg-python-scripts",
      "host": true,
      "features": [
        "cython"
      ]
    }
  ]
}
