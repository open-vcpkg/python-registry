{
  "name": "py-geopandas",
  "version": "1.1.3",
  "port-version": 1,
  "description": "Geographic pandas extensions.",
  "homepage": "https://geopandas.org",
  "license": "BSD-3-Clause",
  "dependencies": [
    "py-numpy",
    "py-pandas",
    "py-pyproj",
    "py-shapely",
    "python3",
    {
      "name": "vcpkg-python-scripts",
      "host": true,
      "features": [
        "versioneer"
      ]
    }
  ],
  "default-features": [
    "pyogrio"
  ],
  "features": {
    "arrow": {
      "description": "I/O speedup with pyogrio",
      "dependencies": [
        {
          "name": "arrow",
          "default-features": false,
          "features": [
            "python"
          ]
        }
      ]
    },
    "fiona": {
      "description": "Use Fiona for input/output of OGR datasources",
      "dependencies": [
        "py-fiona"
      ]
    },
    "pyogrio": {
      "description": "Fast reads of OGR data sources with pyogrio",
      "dependencies": [
        "py-pyogrio"
      ]
    }
  }
}
