{
  "name": "py-duckdb",
  "version": "1.5.0",
  "port-version": 1,
  "description": "Python bindings for high-performance in-process analytical database system",
  "homepage": "https://duckdb.org",
  "license": "MIT",
  "dependencies": [
    {
      "name": "pybind11",
      "features": [
        "scripts"
      ]
    },
    "python3",
    {
      "name": "vcpkg-make",
      "host": true
    },
    {
      "name": "vcpkg-python-scripts",
      "host": true,
      "features": [
        "scikit-build",
        "setuptools-scm"
      ]
    }
  ]
}
